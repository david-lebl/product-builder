#!/usr/bin/env sh
# Mill bootstrap wrapper — downloads Mill automatically if not cached locally.
# Reads the target version from .mill-version in the same directory.
set -e

MILL_VERSION="${MILL_VERSION:-$(cat "$(dirname "$0")/.mill-version" 2>/dev/null | tr -d '[:space:]')}"
MILL_VERSION="${MILL_VERSION:-1.1.3}"

MILL_CACHE_DIR="${HOME}/.cache/mill/download"
MILL_CMD="${MILL_CACHE_DIR}/${MILL_VERSION}"

if [ ! -f "${MILL_CMD}" ]; then
  mkdir -p "${MILL_CACHE_DIR}"
  MILL_URL="https://repo1.maven.org/maven2/com/lihaoyi/mill-dist/${MILL_VERSION}/mill-dist-${MILL_VERSION}-mill.sh"
  printf "Downloading Mill %s from Maven Central...\n" "${MILL_VERSION}" >&2
  curl -fL "${MILL_URL}" -o "${MILL_CMD}"
  chmod +x "${MILL_CMD}"
fi

exec "${MILL_CMD}" "$@"
